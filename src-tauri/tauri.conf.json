{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QiYun List",
  "version": "0.1.0",
  "identifier": "com.qiyunlist.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QiYun List - 规划与四象限管理",
        "width": 1020,
        "height": 720,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      },
      {
        "label": "widget",
        "title": "QiYun List Widget",
        "width": 300,
        "height": 400,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' https: http://localhost:1420 ws://localhost:1421; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "language": ["SimpChinese", "English"]
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QiYun List",
  "version": "0.1.0",
  "identifier": "com.qiyunlist.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QiYun List - 规划与四象限管理",
        "width": 1020,
        "height": 720,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      },
      {
        "label": "widget",
        "title": "QiYun List Widget",
        "width": 300,
        "height": 400,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
